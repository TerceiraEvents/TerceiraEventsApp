{
  "expo": {
    "name": "Terceira Events",
    "slug": "TerceiraEventsApp",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5016"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terceiraevents.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d5016"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.terceiraevents.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2d5016"
        }
      ],
      "expo-calendar",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayEvents",
              "label": "Terceira Events - Today",
              "description": "Shows today's events on Terceira Island",
              "minWidth": "250dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "owner": "chrisrackauckas",
    "extra": {
      "eas": {
        "projectId": "fc3bd113-0884-4800-b6f0-7adcf97f0990"
      }
    }
  }
}
