{
  "expo": {
    "name": "Terceira Events",
    "slug": "TerceiraEventsApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5016"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terceiraevents.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d5016"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.terceiraevents.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "owner": "chrisrackauckas",
    "extra": {
      "eas": {
        "projectId": "fc3bd113-0884-4800-b6f0-7adcf97f0990"
      }
    }
  }
}
